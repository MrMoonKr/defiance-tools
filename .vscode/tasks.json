{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "configure cmake (vs2022-win32)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "vs2022-win32"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "build wadexplorer (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "debug",
                "--target",
                "wadexplorer"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "configure cmake (vs2022-win32)",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile"
            ]
        }
    ]
}
